@model BankSim.Web.ViewModels.TransferViewModel
@{
    ViewData["Title"] = "Para Transferi";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white py-3">
                <h5 class="mb-0 fw-bold">Havale / EFT İşlemi</h5>
            </div>
            <div class="card-body">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <form asp-controller="Transaction" asp-action="Transfer" method="post">

                    <div class="mb-3">
                        <label asp-for="ReceiverIban" class="form-label text-muted fw-bold">Alıcı IBAN</label>
                        <input asp-for="ReceiverIban" class="form-control form-control-lg" placeholder="TR99..." />
                        <span asp-validation-for="ReceiverIban" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label text-muted fw-bold">Gönderilecek Tutar (TL)</label>
                        <input asp-for="Amount" type="number" step="0.01" class="form-control form-control-lg" placeholder="0.00" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label text-muted fw-bold">Açıklama (İsteğe Bağlı)</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Kira, borç ödemesi vb."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg">İşlemi Onayla</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-light">İptal ve Geri Dön</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>