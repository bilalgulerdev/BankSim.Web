@model IEnumerable<BankSim.Web.Models.VirtualCard>
@{
    ViewData["Title"] = "Sanal Kartlarım";
}

<div class="row mt-4">
    <!-- Sol Taraf: Yeni Kart Oluşturma Formu -->
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0 fw-bold">Yeni Sanal Kart Üret</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">İnternet alışverişleriniz için güvenli, limitini sizin belirlediğiniz bir sanal kart oluşturun.</p>

                <form asp-controller="Card" asp-action="Create" method="post">

                    <!-- DİKKAT: Arka planda oluşan hatalar (Bakiye yetersiz, Çok büyük sayı vb.) artık burada görünecek -->
                    <div asp-validation-summary="All" class="text-danger small mb-3 fw-bold"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Kart Limiti (TL)</label>
                        <!-- Tarayıcı seviyesinde de 50 TL altına inilmesini engelliyoruz (min="50") -->
                        <input type="number" name="CardLimit" step="0.01" min="50" class="form-control form-control-lg" placeholder="Örn: 2500" required />
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-dark btn-lg">Kartı Oluştur</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Sağ Taraf: Mevcut Kartların Listesi -->
    <div class="col-md-8">
        <h5 class="mb-3 fw-bold">Aktif Sanal Kartlarınız</h5>

        <div class="row">
            @if (Model != null && Model.Any())
            {
                foreach (var card in Model)
                {
                    <div class="col-md-6 mb-4">
                        <!-- Kart Tasarımı (Responsive) -->
                        <div class="card text-white bg-secondary shadow rounded-4" style="background: linear-gradient(135deg, #2b5876 0%, #4e4376 100%); overflow: hidden;">
                            <div class="card-body p-3 p-sm-4">
                                <div class="d-flex justify-content-between align-items-center mb-3 mb-sm-4">
                                    <h6 class="mb-0 text-uppercase opacity-75" style="letter-spacing: 1px; font-size: clamp(0.8rem, 2vw, 1rem);">Sanal Kart</h6>
                                    <i class="fs-4">💳</i>
                                </div>

                                <!-- Kart Numarası -->
                                <h4 class="card-title mb-3 mb-sm-4 text-nowrap" style="font-size: clamp(1.1rem, 4.5vw, 1.5rem); letter-spacing: clamp(1px, 1.5vw, 3px);">
                                    @string.Format("{0:0000 0000 0000 0000}", long.Parse(card.CardNumber))
                                </h4>

                                <!-- Alt Bilgiler -->
                                <div class="d-flex flex-wrap justify-content-between gap-3">
                                    <div class="flex-grow-0">
                                        <small class="opacity-75 d-block text-nowrap" style="font-size: 0.7rem;">SKT</small>
                                        <span class="fw-bold text-nowrap">@card.ExpiryDate</span>
                                    </div>
                                    <div class="flex-grow-0">
                                        <small class="opacity-75 d-block text-nowrap" style="font-size: 0.7rem;">CVV</small>
                                        <span class="fw-bold text-nowrap">@card.Cvv</span>
                                    </div>
                                    <div class="flex-grow-1 text-start text-sm-end">
                                        <small class="opacity-75 d-block text-nowrap" style="font-size: 0.7rem;">KULLANILABİLİR LİMİT</small>
                                        <span class="fw-bold text-nowrap">@(card.CardLimit - card.UsedBalance) TL</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted py-5">
                    <p>Henüz oluşturulmuş bir sanal kartınız bulunmuyor.</p>
                </div>
            }
        </div>
    </div>
</div>